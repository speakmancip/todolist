# =============================================================================
# Backend Service — Environment Variables
# Copy this file to .env and fill in the values before running the service.
# Never commit .env to version control.
# =============================================================================

# HTTP server port.
# 12-Factor III: all config is injected via the environment, never hard-coded.
PORT=3001

# Path to the SQLite database file.
# Use an absolute path in production. The directory must exist and be writable.
# Integration tests override this with ':memory:' — no file is created.
DB_PATH=./data/todos.db

# Secret key used to sign and verify JSON Web Tokens.
# Must be a long, random string. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED — the service will refuse to start if this is missing or set to the placeholder.
JWT_SECRET=change-me-in-production

# JWT expiry duration (any value accepted by the jsonwebtoken library).
# Examples: '1h', '7d', '30m'
JWT_EXPIRES_IN=1h
