# =============================================================================
# Frontend (React SPA) — Environment Variables
# Copy this file to .env and fill in the values before running the app.
# Never commit .env to version control.
#
# Vite convention: only variables prefixed with VITE_ are exposed to the browser.
# =============================================================================

# Base URL of the BFF service.
# This must be reachable from the user's browser — it is NOT a server-side value.
# In production, replace with the public URL of the deployed BFF.
VITE_BFF_URL=http://localhost:3002
