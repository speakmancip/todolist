# =============================================================================
# BFF (Backend for Frontend) — Environment Variables
# Copy this file to .env and fill in the values before running the service.
# Never commit .env to version control.
# =============================================================================

# HTTP server port for the BFF.
PORT=3002

# Base URL of the backend service.
# The BFF prefixes every backend API call with this URL.
# In production, replace with the internal/private URL of the backend service.
BACKEND_URL=http://localhost:3001

# The origin of the React SPA — used to configure CORS.
# The browser will only allow requests from this origin.
# In production, set this to the public URL of the deployed frontend.
CORS_ORIGIN=http://localhost:5173
